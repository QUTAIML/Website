---
import "@/styles/about/constitution.css";
import Navigation from "@/components/Navigation.astro";
import Footer from "@/components/Footer.astro";
import { marked } from "marked";

const rawURL = "https://raw.githubusercontent.com/QUT-AIML/Constitution/main/README.md";

let constitutionHTML = "";

try {
  const res = await fetch(rawURL);
  if (!res.ok) throw new Error(`Failed to fetch: ${res.status}`);

  const md = await res.text();

  // Convert Markdown to HTML
  constitutionHTML = marked.parse(md);

} catch (err) {
  console.error("Error fetching constitution:", err);
  constitutionHTML = `<p>Error fetching constitution: ${err.message}</p>`;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="QUT AI & ML Society Constitution" />
    <title>QUT AI & ML Society</title>
  </head>

  <body class="background-dots">
    <Navigation />

    <div class="content-wrapper top-space vacant-space">
      <section class="pink-panel">
        <p class="pink-title">Our Constitution</p>
      </section>

      <div class="info-panel-wrapper">
        <section class="info-panel">
          <div class="constitution-content" set:html={constitutionHTML}></div>
        </section>
      </div>
    </div>

    <Footer />
  </body>
</html>
