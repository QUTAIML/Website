---
import "@/styles/global.css";
import "@/styles/about/about.css";
import Navigation from "@/components/Navigation.astro";
import Footer from "@/components/Footer.astro";

// Import all team-details.json files eagerly from all year folders
const teamFiles = import.meta.glob('/public/data/about/*/team-details.json', { eager: true });

// Map to { path, year } objects, ignoring non-numeric folders like Template
const teamFileYears = Object.keys(teamFiles)
  .map(path => {
    const folderName = path.split("/").at(-2);
    const year = parseInt(folderName);
    return { path, year, valid: /^\d{4}$/.test(folderName) };
  })
  .filter(f => f.valid);

// Pick the latest numeric year
const latestTeamFile = teamFileYears
  .sort((a, b) => b.year - a.year)[0];

if (!latestTeamFile) {
  throw new Error("No valid year found in about data");
}

// Get the JSON array from that file
const latestTeamData = teamFiles[latestTeamFile.path].default;

// Normalise image paths for exec-photos
const teamsForClient = latestTeamData.map(section => ({
  ...section,
  items: section.items.map(member => ({
    ...member,
    image: member.image
      ? `/data/about/${latestTeamFile.year}/exec-photos/${member.image}`
      : null,
  })),
}));

---




<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
