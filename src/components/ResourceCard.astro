---
interface Props {
  title: string;
  description: string;
  href: string;
}

const { title, description, href } = Astro.props;
---

<div class="team-card resource-card">
  <div class="team-info">
    <h3>{title}</h3>
    <p>{description}</p>
    <a href={href} class="resource-link">View more</a>
  </div>
</div>