---
import "@/styles/home.css";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import InfoPanel from "@/components/InfoPanel.astro";
import { upcomingEvents } from "@/scripts/index/home-loader";
---

<BaseLayout>
  <div>

    <!-- HERO CAROUSEL -->
     
    <div class="hero-carousel">
      <!-- Add as many slides as you like -->
      <div class="hero-slide active" style="background-image: url('/data/home/1.png')"></div>
      <div class="hero-slide" style="background-image: url('/data/home/2.png')"></div>
      <div class="hero-slide" style="background-image: url('/data/home/3.JPG')"></div>
      <div class="hero-slide" style="background-image: url('/data/home/4.png')"></div>

      <!-- Dot indicators -->
      <div class="hero-dots">
        <span class="hero-dot active" data-index="0"></span>
        <span class="hero-dot" data-index="1"></span>
        <span class="hero-dot" data-index="2"></span>
        <span class="hero-dot" data-index="3"></span>
      </div>
    </div>


    <!-- WELCOME -->
    <div class="content-wrapper large-space">
      <SectionHeader title="Welcome to the QUT AI & ML Society" />
      <InfoPanel>
        <p class="section-content">
          Where students come together to explore, experiment, and innovate in the world of AI and ML.
        </p>
        <p class="section-content section-space">
          Join the QUT AI & ML Society (AIML) as we host hands-on workshops, competitions, and industry-sponsored
          events designed to challenge your skills and spark your creativity.
        </p>
        <p class="section-content section-space">
          Ready to take your AI journey to the next level? Let's learn, build, and innovate together.
        </p>
      </InfoPanel>
    </div>

    <!-- TOOLKIT -->
    <div class="content-wrapper large-space">
      <SectionHeader title="Machine Learning Engineer's Toolkit" />
      <section class="toolkit-section">
        <div class="toolkit-inner">
          <div class="toolkit-grid">
            <div class="toolkit-line-behind"></div>
            <div class="toolkit-column">
              <div class="toolkit-header-card">Programming Languages</div>
              <article class="toolkit-card">
                <ul class="card-list">
                  <li><strong>Python</strong> — Core language for AI, ML, and data science.</li>
                  <li>
                    Learn Python for ML:
                    <a href="https://www.freecodecamp.org/learn" target="_blank" rel="noopener">
                      freeCodeCamp Python
                    </a>
                  </li>
                  <li>Scientific computing & ML libraries: NumPy, Pandas, PyTorch, TensorFlow</li>
                </ul>
              </article>
            </div>
            <div class="toolkit-column">
              <div class="toolkit-header-card">Essential Tools</div>
              <article class="toolkit-card">
                <ul class="card-list">
                  <li><strong>Jupyter Notebooks</strong> — Interactive experiments & visualisation.</li>
                  <li><strong>Google Colab</strong> — Free GPUs, zero setup, perfect for ML.</li>
                  <li><strong>PyCharm</strong> — Professional Python IDE for larger projects.</li>
                  <li><strong>VS Code</strong> — Lightweight editor with strong ML extensions.</li>
                </ul>
              </article>
            </div>
            <div class="toolkit-column">
              <div class="toolkit-header-card">AI & ML Tips</div>
              <article class="toolkit-card">
                <ul class="card-list">
                  <li>Start simple — baseline models beat complex ones done poorly.</li>
                  <li>Visualise your data before training any model.</li>
                  <li>Track experiments (metrics, params, datasets).</li>
                  <li>Learn the math intuition, not just the APIs.</li>
                </ul>
              </article>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- UPCOMING EVENTS -->
    <SectionHeader title="Upcoming Events" />
    <section class="events-panel">
      {upcomingEvents.length > 0 ? (
        <div id="upcoming-events-grid" class="events-grid">
          {upcomingEvents.map(ev => (
            <article
              class="event-card"
              data-semester={ev.semesterId}
              data-category={ev.category}
              data-type={ev.type ?? ev.category ?? "Other"}
              data-title={ev.title.toLowerCase()}
              data-date={ev.date}
            >
              {ev.rubric && ev.rubric.trim() !== "" ? (
                <a href={ev.rubric}>
                  <div class="card-media">
                    {ev.image ? <img src={ev.image} alt={ev.title} /> : <div class="no-image">No image</div>}
                  </div>
                  <div class="card-body">
                    <h3 class="card-title">{ev.title}</h3>
                    <div class="card-divider"></div>
                    <time class="card-date">{ev.dateLabel}</time>
                    <p class="card-description">{ev.excerpt}</p>
                    <div class="card-footer">
                      <span class="card-view-more">View more →</span>
                    </div>
                  </div>
                </a>
              ) : (
                <div>
                  <div class="card-media">
                    {ev.image ? <img src={ev.image} alt={ev.title} /> : <div class="no-image">No image</div>}
                  </div>
                  <div class="card-body">
                    <h3 class="card-title">{ev.title}</h3>
                    <div class="card-divider"></div>
                    <time class="card-date">{ev.dateLabel}</time>
                    <p class="card-description">{ev.excerpt}</p>
                  </div>
                </div>
              )}
            </article>
          ))}
        </div>
      ) : (
        <div class="no-events-state">
          <p class="no-events-title">No upcoming events right now</p>
          <p class="no-events-text">
            We're working on new workshops, talks, and projects.
            <br />
            Follow us or join our community to be the first to know.
          </p>
        </div>
      )}
    </section>

  </div>

  <Fragment slot="scripts">
    <script type="module">
      import "/src/scripts/home/home-script.js";
    </script>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        var slides = Array.from(document.querySelectorAll(".hero-slide"));
        var dots   = Array.from(document.querySelectorAll(".hero-dot"));
        if (slides.length === 0) return;

        var current = 0;
        var timer;

        function goTo(index) {
          slides[current].classList.remove("active");
          if (dots[current]) dots[current].classList.remove("active");
          current = (index + slides.length) % slides.length;
          slides[current].classList.add("active");
          if (dots[current]) dots[current].classList.add("active");
        }

        function startAuto() { timer = setInterval(function () { goTo(current + 1); }, 5000); }
        function resetAuto() { clearInterval(timer); startAuto(); }

        dots.forEach(function (dot, i) {
          dot.addEventListener("click", function () { goTo(i); resetAuto(); });
        });

        startAuto();
      });
    </script>
  </Fragment>


</BaseLayout>