---
import "@/styles/contact.css";
import ContentLayout from "@/layouts/ContentLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
---

<ContentLayout>
  <div class="content-wrapper about-space">
    <SectionHeader title="Our Community" />
    <div class="info-panel-wrapper">
      <section class="info-panel">
        Below are our social media platforms where we can be reached
      </section>
      <a href="https://linktr.ee/QUT_AMS" class="button-outline-pink">
        Our Link tree
      </a>
    </div>
  </div>

  <div class="content-wrapper">
    <SectionHeader title="Get in Contact" class="contact-space" />
    <div class="info-panel-wrapper">
      <section class="info-panel">
        Please fill in the form below and we will get back to you as soon as possible.
      </section>
      <a href="mailto:qut-aiml@outlook.com" class="button-outline-pink contact-bottom-space">
        Reach out to us here
      </a>
    </div>
  </div>
</ContentLayout>