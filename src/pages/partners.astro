---
import "@/styles/global.css";
import "@/styles/partners.css";
import Navigation from "@/components/Navigation.astro";
import Footer from "@/components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="QUT AI & ML Society Sponsors Page" />
    <title>QUT AI & ML Society</title>
  </head>

  <body class="background-dots">
    <Navigation />

    <div class="content-wrapper top-space vacant-space">

      <section class="pink-panel">
        <p class="pink-title">Our Partners</p>
      </section>

      <div class="sponsor-wrapper">
        <img src="/data/sponsors/NTI.png" alt="NTI Logo" class="sponsor-logo sponsor-clickable" />
      </div>

      <!-- Modal -->
      <div id="sponsorModal" class="photo-modal">
        <span id="sponsorModalClose" class="photo-modal-close">&times;</span>
        <img id="sponsorModalImg" class="photo-modal-content" />
      </div>

      <div class="info-panel-wrapper">
        <div class="thick-line-behind"></div>      
        <section class="info-panel">
          <p>We're still finalising our partnerships for 2026</p>
          <p>Stay tuned to see the incoming organisations sponsoring QUT AI & ML Society.</p>
        </section>
      </div>
    </div>

    <Footer />
  </body>
</html>



<script>
  const img = document.querySelector('.sponsor-clickable');
  const modal = document.getElementById('sponsorModal');
  const modalImg = document.getElementById('sponsorModalImg');
  const closeBtn = document.getElementById('sponsorModalClose');

  img.onclick = () => {
    modal.style.display = 'flex';
    modalImg.src = img.src;
    document.body.classList.add('modal-open');
  };

  closeBtn.onclick = () => {
    modal.style.display = 'none';
    document.body.classList.remove('modal-open');
  };

  modal.onclick = (e) => {
    if (e.target === modal) {
      modal.style.display = 'none';
      document.body.classList.remove('modal-open');
    }
  };
</script>
