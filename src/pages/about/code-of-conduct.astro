---
import "@/styles/global.css";
import "@/styles/about/about.css";
import "@/styles/about/constitution.css";
import Navigation from "@/components/Navigation.astro";
import Footer from "@/components/Footer.astro";
import { marked } from "marked";

const rawURL =
  "https://raw.githubusercontent.com/QUT-AIML/Code-of-Conduct/refs/heads/main/README.md";

let cocHTML = "";

try {
  const res = await fetch(rawURL);
  if (!res.ok) throw new Error(`Failed to fetch: ${res.status}`);

  const md = await res.text();

  // Custom renderer for heading styling
  const renderer = new marked.Renderer();

  renderer.heading = function (token) {
    const level = token.depth;
    const innerHtml = this.parser.parseInline(token.tokens);
    const rawText = token.text;

    const slug = rawText
      .toLowerCase()
      .replace(/[^\w]+/g, "-")
      .replace(/(^-|-$)/g, "");

    if (level === 2) {
      return `<h2 id="${slug}" class="h2-pink">${innerHtml}</h2>`;
    }

    if (level === 3) {
      return `<h3 id="${slug}" class="h3-link">${innerHtml}</h3>`;
    }

    return `<h${level} id="${slug}">${innerHtml}</h${level}>`;
  };

  cocHTML = marked.parse(md, { renderer });
} catch (err) {
  console.error("Error fetching Code of Conduct:", err);
  cocHTML = `<p>Error fetching Code of Conduct.</p>`;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="QUT AI & ML Society Code of Conduct" />
    <title>QUT AI & ML Society</title>
  </head>

  <body class="background-dots">
    <Navigation />

    <div class="content-wrapper about-space bottom-space">

      <section class="pink-panel constitution-space">
        <p class="pink-title">Code of Conduct</p>
      </section>

      <div class="info-panel-wrapper">
        <section class="info-panel special-padding">
          <div
            class="coc-content"
            set:html={cocHTML}
          ></div>
        </section>
      </div>
    </div>

    <Footer />
  </body>
</html>
