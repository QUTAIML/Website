---
import SectionHeader from "@/components/SectionHeader.astro";

interface Props {
  title: string;
  class?: string;
}

const {
  title,
  class: className = "",
} = Astro.props;
---

<div class="content-wrapper">
  <SectionHeader title={title} class="resources-header" />

  <section class="resources-section">
    <div class={`team-grid-wrapper ${className}`}>
      <div class="team-row">
        <div class="team-grid resources-grid">
          <slot />
        </div>
      </div>
    </div>
  </section>
</div>