---
import { marked } from "marked";
import "@/styles/global.css";
import "@/styles/about/exec-application.css";
import Navigation from "@/components/Navigation.astro";
import Footer from "@/components/Footer.astro";

const rawURL =
  "https://raw.githubusercontent.com/QUT-AIML/Constitution/main/Role-Descriptions.md";

marked.setOptions({
  gfm: true,
  breaks: false,
  headerIds: true,
  mangle: false,
});

let rolesHTML = "";

try {
  const res = await fetch(rawURL);
  if (!res.ok) throw new Error(`Failed to fetch: ${res.status}`);

  let md = await res.text();

  // Remove all occurrences of [!NOTE] in blockquotes
  md = md.replace(/>\s*\[!NOTE\]/g, ">");

  const renderer = new marked.Renderer();
  rolesHTML = marked.parse(md, { renderer });
} catch (err) {
  console.error("Error fetching Role Descriptions:", err);
  rolesHTML = `<p>Error loading executive role descriptions.</p>`;
}
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="QUT AI & ML Society Executive Applications"
    />
    <title>QUT AI & ML Society</title>
  </head>

  <body class="background-dots">
    <Navigation />

    <div class="content-wrapper top-space">

      <!-- PAGE TITLE -->
      <section class="pink-panel">
        <p class="pink-title">Executive Applications</p>
      </section>

      <!-- INTRO -->
      <div class="info-panel-wrapper full-space">
        <div class="thick-line-behind"></div>
        <section class="info-panel">
          <p>
            The QUT AI & ML Society executive team is responsible for leading
            the club’s operations, events, and long term direction.
          </p>
        </section>
      </div>

      </div>

    <div class="content-wrapper spacing-above">

      <!-- WHEN APPLICATIONS OPEN -->
      <section class="pink-panel ">
        <p class="pink-title">When Do Applications Open?</p>
      </section>

      <div class="info-panel-wrapper spacing-bottom full-space">
        <section class="info-panel">
          <p>
            Executive applications open once per year at the club’s Annual General Meeting. Every executive position is declared vacant and open for re election at the AGM.
          </p>
        </section>
      </div>

    </div>

    <div class="content-wrapper spacing-above">


      <!-- EXEC STRUCTURE -->
      <section class="pink-panel">
        <p class="pink-title">Executive Team Structure</p>
      </section>

      <div class="info-panel-wrapper scroll-horizontal">
        <section class="info-panel">

          <div class="exec-org-chart">

            <!-- SVG OVERLAY FOR CONNECTOR LINES -->
            <svg class="exec-connector-layer"></svg>

            <!-- ROW 1: CORE EXEC -->
            <div class="exec-row top-row">
              <div class="exec-group pink-group">
                <div class="group-title">Admin Team</div>
                <div class="exec-sub-row">
                  <div class="exec-node" data-id="president">President</div>
                  <div class="exec-node" data-id="vp" data-parent="president">Vice President</div>
                  <div class="exec-node" data-id="secretary" data-parent="president">Secretary</div>
                  <div class="exec-node" data-id="treasurer" data-parent="president">Treasurer</div>
                </div>
              </div>
            </div>

            <!-- ROW 2: TEAMS -->
            <div class="exec-row second-row">

              <!-- MARKETING TEAM -->
              <div class="exec-group pink-group">
                <div class="group-title">Marketing Team</div>
                <div class="exec-node" data-id="marketing-director" data-parent="president">
                  Marketing Director
                </div>
                <div class="exec-sub-row">
                  <div class="exec-node" data-id="social-media" data-parent="marketing-director">
                    Social Media Manager
                  </div>
                  <div class="exec-node" data-id="reels-video" data-parent="marketing-director">
                    Reels & Video Officer
                  </div>
                  <div class="exec-node" data-id="graphic-designer" data-parent="marketing-director">
                    Graphic Designer
                  </div>
                </div>
              </div>

              <!-- PROJECTS TEAM -->
              <div class="exec-group pink-group">
                <div class="group-title">Projects Team</div>
                <div class="exec-sub-row">
                  <div class="exec-node" data-id="projects-director" data-parent="president">
                    Projects Director
                  </div>
                  <div class="exec-node" data-id="projects-manager" data-parent="projects-director">
                    Projects Manager
                  </div>
                </div>
                <div class="exec-sub-row wrap">
                  <div class="exec-node" data-id="projects-officer-1" data-parent="projects-manager">Projects Officer</div>
                  <div class="exec-node" data-id="projects-officer-2" data-parent="projects-manager">Projects Officer</div>
                  <div class="exec-node" data-id="projects-officer-3" data-parent="projects-manager">Projects Officer</div>
                  <div class="exec-node" data-id="projects-officer-4" data-parent="projects-manager">Projects Officer</div>
                  <div class="exec-node" data-id="projects-officer-5" data-parent="projects-manager">Projects Officer</div>
                </div>
              </div>

              <!-- EVENTS TEAM -->
              <div class="exec-group pink-group">
                <div class="group-title">Events Team</div>
                <div class="exec-node" data-id="events-director" data-parent="president">
                  Events Director
                </div>
                <div class="exec-sub-row">
                  <div class="exec-node" data-id="af-1" data-parent="events-director">Activities Facilitator</div>
                  <div class="exec-node" data-id="af-2" data-parent="events-director">Activities Facilitator</div>
                  <div class="exec-node" data-id="af-3" data-parent="events-director">Activities Facilitator</div>
                </div>
              </div>

              <!-- SUPPORT TEAM -->
              <div class="exec-group pink-group">
                <div class="group-title">Support Team</div>
                <div class="exec-sub-row">
                  <div class="exec-node" data-id="industry-director" data-parent="president">
                    Industry Director
                  </div>
                  <div class="exec-node" data-id="engagement-officer" data-parent="president">
                    Engagement Officer
                  </div>
                </div>
              </div>

            </div>
          </div>

        </section>
      </div>

      </div>

    <div class="content-wrapper spacing-above spacing-below">


      <!-- ROLES AND RESPONSIBILITIES -->
      <section class="pink-panel">
        <p class="pink-title">Roles and Responsibilities</p>
      </section>

      <div class="info-panel-wrapper">
        <section class="info-panel special-padding">
          <div class="roles-content" set:html={rolesHTML}></div>
        </section>
      </div>

    </div>

    <Footer />

  </body>
</html>
