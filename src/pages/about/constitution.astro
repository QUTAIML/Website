---
import "@/styles/global.css";
import "@/styles/about/about.css";
import "@/styles/about/constitution.css";
import Navigation from "@/components/Navigation.astro";
import Footer from "@/components/Footer.astro";
import { marked } from "marked";

const rawURL =
  "https://raw.githubusercontent.com/QUT-AIML/Constitution/main/README.md";

let constitutionHTML = "";

try {
  const res = await fetch(rawURL);
  if (!res.ok) throw new Error(`Failed to fetch: ${res.status}`);

  const md = await res.text();

  // Custom renderer for heading styling
  const renderer = new marked.Renderer();

  let inTOC = false;

  renderer.heading = function (token) {
    const level = token.depth;
    const innerHtml = this.parser.parseInline(token.tokens);
    const rawText = token.text;

    // Detect start of TOC
    if (level === 2 && rawText.trim().toLowerCase() === "contents") {
      inTOC = true;
      return `<h2 class="h2-pink">Contents</h2><div class="toc">`;
    }

    // Detect TOC items
    const isTOC = inTOC && level === 3 && /^\d+\./.test(rawText);

    if (isTOC) {
      return `<div class="toc-item">${innerHtml}</div>`;
    }

    // Detect end of TOC (first non‑TOC heading)
    if (inTOC && level === 2 && rawText.trim().toLowerCase() !== "contents") {
      inTOC = false;
      // close TOC wrapper
      return `</div><h2 id="${token.slug}" class="h2-pink">${innerHtml}</h2>`;
    }

    // Normal headings
    const slug = rawText
      .toLowerCase()
      .replace(/[^\w]+/g, "-")
      .replace(/(^-|-$)/g, "");

    if (level === 2) {
      return `<h2 id="${slug}" class="h2-pink">${innerHtml}</h2>`;
    }

    if (level === 3) {
      return `<h3 id="${slug}" class="h3-link">${innerHtml}</h3>`;
    }

    return `<h${level} id="${slug}">${innerHtml}</h${level}>`;
  };


  constitutionHTML = marked.parse(md, { renderer });
} catch (err) {
  console.error("Error fetching constitution:", err);
  constitutionHTML = `<p>Error fetching constitution.</p>`;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="QUT AI & ML Society Constitution" />
    <title>QUT AI & ML Society</title>
  </head>

  <body class="background-dots">
    <Navigation />

    <div class="content-wrapper about-space bottom-space">

      <div class="info-panel-wrapper">
        <div class="thick-line"></div>			
          <section class="info-panel">
            <p>
              This is the QUT AIML constitution – the set of rules that govern the society.
              Any changes to the constitution must be requested and voted on at a General Meeting.
              Proposals can be made through the submission of issues to this GitHub repository
              by members of the society.
              <br /><br />
              <a class="constitution-link" href="https://github.com/QUT-AIML/Constitution" target="_blank">
                View the Constitution Repository →
              </a>
            </p>
          </section>
      </div>


      <section class="pink-panel constitution-space">
        <p class="pink-title">Our Constitution</p>
      </section>

      <div class="info-panel-wrapper">
        <section class="info-panel special-padding">
          <div
            class="constitution-content"
            set:html={constitutionHTML}
          ></div>
        </section>
      </div>
    </div>

    <Footer />
  </body>
</html>
