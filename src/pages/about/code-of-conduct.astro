---
import { marked } from "marked";
import "@/styles/global.css";
import "@/styles/about/about.css";
import "@/styles/about/code-of-conduct.css";
import Navigation from "@/components/Navigation.astro";
import Footer from "@/components/Footer.astro";

const rawURL =
  "https://raw.githubusercontent.com/QUT-AIML/Code-of-Conduct/main/README.md";

marked.setOptions({
  gfm: true,
  breaks: false,
  headerIds: true,
  mangle: false,
});

let cocHTML = "";

try {
  const res = await fetch(rawURL);
  if (!res.ok) throw new Error(`Failed to fetch: ${res.status}`);

  const md = await res.text();

  console.log("===== RAW MARKDOWN (first 400 chars) =====");
  console.log(md.slice(0, 400));

  const renderer = new marked.Renderer();

  cocHTML = marked.parse(md, { renderer });

  console.log("===== PARSED HTML CHECK =====");
  console.log("Contains <ul>:", cocHTML.includes("<ul"));
  console.log("Contains <li>:", cocHTML.includes("<li"));
  console.log("Contains '<p>-':", cocHTML.includes("<p>-"));

  const firstUlIndex = cocHTML.indexOf("<ul");
  console.log("First <ul> index:", firstUlIndex);

  if (firstUlIndex !== -1) {
    console.log("===== HTML AROUND FIRST <ul> =====");
    console.log(
      cocHTML.slice(
        Math.max(0, firstUlIndex - 300),
        firstUlIndex + 1500
      )
    );
  } else {
    console.log("No <ul> found in HTML.");
  }

} catch (err) {
  console.error("Error fetching Code of Conduct:", err);
  cocHTML = `<p>Error fetching Code of Conduct.</p>`;
}
---


<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="QUT AI & ML Society Code of Conduct" />
    <title>QUT AI & ML Society</title>
  </head>

  <body class="background-dots">
    <Navigation />

    <div class="content-wrapper about-space bottom-space">
      <section class="pink-panel constitution-space">
        <p class="pink-title">Code of Conduct</p>
      </section>

      <div class="info-panel-wrapper">
        <section class="info-panel special-padding">
          <div class="coc-content" set:html={cocHTML}></div>
        </section>
      </div>
    </div>

    <Footer />
  </body>
</html>
