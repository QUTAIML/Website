---
import "@/styles/about/about.css";
import ContentLayout from "@/layouts/ContentLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import InfoPanel from "@/components/InfoPanel.astro";
import { loadAboutData } from "@/scripts/about/exec-data";

const { teamsForClient, degreesForClient } = loadAboutData();
---

<ContentLayout>
  <div class="content-wrapper about-space">

    <!-- ABOUT -->
    <SectionHeader title="About QUT AIML" />
    <InfoPanel>
      The QUT AI & ML Society is Queensland's largest university society dedicated to artificial intelligence and machine learning.
      AIML is a student-led community for students across Engineering, IT, Data Science, Business, and other disciplines.
      Whether you are new to AI or already building projects, AIML gives you clear ways to get involved.
      Through hackathons, competitions, industry events, and project nights, we help members turn their interest into practical experience.
      With project topics ranging from regression and clustering to transformers and large language models, AIML gives members a place to gain experience and contribute to meaningful technical work.
    </InfoPanel>

    <div class="content-wrapper objective-space">

      <!-- OBJECTIVES -->
      <div class="objectives-wrapper">
        <div class="thick-line-behind"></div>
        <section class="objectives-section">
          <div class="objectives-inner">
            <div class="objectives-header">
              <span class="banner left"></span>
              <h2>OUR<br /><span>OBJECTIVES</span></h2>
              <span class="banner right"></span>
            </div>
            <div class="objectives-cards">
              <div class="objective-item">
                <div class="objective-number">1</div>
                <div class="objective-card">
                  <p>Gain insights and guidance from alumni, professionals, and leaders in the AI and ML industry.</p>
                </div>
              </div>
              <div class="objective-item">
                <div class="objective-number">2</div>
                <div class="objective-card">
                  <p>Collaborate, experiment, and build impactful projects focused on artificial intelligence and machine learning.</p>
                </div>
              </div>
              <div class="objective-item">
                <div class="objective-number">3</div>
                <div class="objective-card">
                  <p>Connect and network with students, researchers, and professionals in the AI, ML, and broader tech community.</p>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>

      <!-- DEGREES -->
      <section class="degree-section">
        <section class="pink-panel-flex">
          <p class="pink-title">Relevant Degrees</p>
        </section>
        <div class="content-wrapper centered-box">
          <section class="minimal-padding-panel spacing-top">
            <p class="section-content">
              <div id="degree-title" class="degree-name"></div>
            </p>
          </section>
        </div>
        <div class="degree-grid-wrapper">
          <div class="degree-row">
            <div class="side-bar left">
              <button class="carousel-arrow-degree left-degree">‹</button>
            </div>
            <div
              class="degree-grid"
              id="degrees-grid"
              data-teams={JSON.stringify(degreesForClient)}
            ></div>
            <div class="side-bar right">
              <button class="carousel-arrow-degree right-degree">›</button>
            </div>
          </div>
          <div class="degree-dots" id="degrees-dots"></div>
        </div>
        <div class="degree-arrows-mobile-panel">
          <button class="carousel-arrow left">‹</button>
          <button class="carousel-arrow right">›</button>
        </div>
      </section>

      <!-- USEFUL RESOURCES -->
      <div class="content-wrapper">
        <SectionHeader title="Useful Resources" class="resources-header" />
        <section class="resources-section">
          <div class="team-grid-wrapper small-bottom-spacing">
            <div class="team-row">
              <div class="team-grid resources-grid">
                <div class="team-card resource-card">
                  <div class="team-info">
                    <h3>Frequently Asked Questions</h3>
                    <p>Answers to common questions about membership, events, and involvement.</p>
                    <a href="/about/faq" class="resource-link">View more</a>
                  </div>
                </div>
                <div class="team-card resource-card">
                  <div class="team-info">
                    <h3>Our Community</h3>
                    <p>Learn about our culture, values, and what makes AIML special.</p>
                    <a href="/about/community" class="resource-link">View more</a>
                  </div>
                </div>
                <div class="team-card resource-card">
                  <div class="team-info">
                    <h3>Constitution</h3>
                    <p>Our governing document outlining structure, roles, and processes.</p>
                    <a href="https://github.com/QUT-AIML/Constitution/blob/main/Role-Descriptions.md" class="resource-link">View more</a>
                  </div>
                </div>
                <div class="team-card resource-card">
                  <div class="team-info">
                    <h3>Code of Conduct</h3>
                    <p>Guidelines to ensure a safe, inclusive, and respectful community.</p>
                    <a href="https://github.com/QUT-AIML/Code-of-Conduct" class="resource-link">View more</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>

      <!-- TEAM -->
      <section class="team-section">
        <div class="pink-panel-flex">
          <p class="pink-title">Meet the Team</p>
        </div>
        <div class="content-wrapper centered-box">
          <section class="minimal-padding-panel spacing-top">
            <p class="section-content">
              <div id="team-title" class="team-name"></div>
            </p>
          </section>
        </div>
        <div class="team-grid-wrapper">
          <div class="team-row">
            <div class="side-bar left">
              <button class="carousel-arrow left">‹</button>
            </div>
            <div
              class="team-grid"
              id="team-grid"
              data-teams={JSON.stringify(teamsForClient)}
            ></div>
            <div class="side-bar right">
              <button class="carousel-arrow right">›</button>
            </div>
          </div>
          <div class="team-dots" id="team-dots"></div>
        </div>
        <div class="team-arrows-mobile-panel">
          <button class="carousel-arrow left">‹</button>
          <button class="carousel-arrow right">›</button>
        </div>
      </section>

      <!-- EXECUTIVE BODY -->
      <div class="content-wrapper">
        <SectionHeader title="The Executive Body" class="resources-header" />
        <section class="resources-section">
          <div class="team-grid-wrapper bottom-spacing">
            <div class="team-row">
              <div class="team-grid resources-grid">
                <div class="team-card resource-card">
                  <div class="team-info">
                    <h3>How to become an Executive</h3>
                    <p>Learn about the application process, expectations, and responsibilities of AIML executives.</p>
                    <a href="/about/exec-application" class="resource-link">View more</a>
                  </div>
                </div>
                <div class="team-card resource-card">
                  <div class="team-info">
                    <h3>Our History</h3>
                    <p>Learn about the teams that have shaped our club over the years.</p>
                    <a href="/about/history" class="resource-link">View more</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>

    </div>
  </div>

  <Fragment slot="scripts">
    <script type="module">
      import "/src/scripts/about/about-script.js";
    </script>
  </Fragment>
</ContentLayout>