---
import "@/styles/global.css";
import "@/styles/partners.css";
import Navigation from "@/components/Navigation.astro";
import Footer from "@/components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="QUT AI & ML Society Sponsors Page" />
    <title>QUT AI & ML Society</title>
  </head>

  <body class="background-dots">
    <Navigation />

    <div class="content-wrapper top-space vacant-space">

      <section class="pink-panel">
        <p class="pink-title">Our Sponsors</p>
      </section>

      <div class="info-panel-wrapper">
        <div class="thick-line-small"></div>      
        <section class="info-panel">
          <p>Our sponsors are the select organisations that form an exclusive partnership with the QUT AI & ML Society.
            They provide critical support, helping us deliver high-impact initiatives, workshops, and events for our members. 
            Sponsorship comes with a deeper engagement, reflecting a strategic collaboration with our society’s mission.</p>
        </section>
      </div>


      <div class="sponsor-wrapper">
        <a href="https://www.nti.com.au" target="_blank" rel="noopener noreferrer">
          <img src="/data/sponsors/NTI.png" alt="NTI Logo" class="sponsor-logo" />
        </a>
      </div>



      <section class="pink-panel">
        <p class="pink-title">Our Supporters</p>
      </section>

      <div class="info-panel-wrapper vacant-space">
        <div class="thick-line-small"></div>      
        <section class="info-panel">
          <p>
            Our supporters are valued organisations who champion the QUT AI & ML Society and contribute to member experiences in meaningful ways. 
            While this group is smaller and curated, the support is more general and flexible, helping provide direct access to opportunities, insights, 
            and resources that enhance our community.
          </p>
        </section>
      </div>

  


      <div class="info-panel-wrapper">
        <section class="info-panel history-box">
          <div class="team-split static-layout equal-height">

            {/* LEFT: Image */}
            <div class="team-photo-large">
              <div class="image-wrapper" style="position: relative;">
                <div class="loader" id="loader-microsoft">
                  <div class="spinner"></div>
                </div>
                <img
                  src="/data/supporters/Microsoft.png"
                  alt="Microsoft"
                  class="team-hero"
                  id="teamHero-microsoft"
                  onload="document.getElementById('loader-microsoft').style.display='none'"
                  style="display: block;"
                />
              </div>
            </div>

            {/* RIGHT: Text */}
            <aside class="yearbook">
              <h3 class="company-title">Microsoft</h3>
              <p class="company-description">
                Microsoft is a global technology company known for its software, cloud computing, and AI innovations. The company develops tools and platforms that empower individuals, businesses, and organisations worldwide to achieve more through technology.
              </p>
              <a href="https://www.microsoft.com" target="_blank" rel="noopener noreferrer" class="view-details-link">
                View more details here
              </a>
            </aside>


          </div>
        </section>
      </div>

      <div class="info-panel-wrapper">
        <section class="info-panel history-box">
          <div class="team-split static-layout equal-height">

            {/* LEFT: Image */}
            <div class="team-photo-large">
              <div class="image-wrapper" style="position: relative;">
                <div class="loader" id="loader-acs">
                  <div class="spinner"></div>
                </div>
                <img
                  src="/data/supporters/ACS.png"
                  alt="Australian Computing Society"
                  class="team-hero"
                  id="teamHero-acs"
                  onload="document.getElementById('loader-acs').style.display='none'"
                  style="display: block;"
                />
              </div>
            </div>

            {/* RIGHT: Text */}
            <aside class="yearbook">
              <h3 class="company-title">Australian Computing Society</h3>
              <p class="company-description">
                The Australian Computing Society (ACS) is Australia’s leading professional association for IT practitioners. ACS advocates for excellence, professional development, and ethical practice across the technology sector, connecting members and advancing knowledge in tech.
              </p>
              <a href="https://www.acs.org.au" target="_blank" rel="noopener noreferrer" class="view-details-link">
                View more details here
              </a>
            </aside>

          </div>
        </section>
      </div>


      <div class="info-panel-wrapper">
          <div class="thick-line-small"></div>      
          <section class="info-panel">
            <p>We're still finalising our partnerships for 2026</p>
            <p>Stay tuned to see the incoming organisations sponsoring QUT AI & ML Society.</p>
          </section>
        </div>


      <!-- Modal -->
      <div id="sponsorModal" class="photo-modal">
        <span id="sponsorModalClose" class="photo-modal-close">&times;</span>
        <img id="sponsorModalImg" class="photo-modal-content" />
      </div>

    </div>

    <Footer />
  </body>
</html>


