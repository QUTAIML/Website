---
import { marked } from "marked";
import "@/styles/global.css";
import "@/styles/partners.css";
import "@/styles/about/exec-application.css";
import Navigation from "@/components/Navigation.astro";
import Footer from "@/components/Footer.astro";

const rawURL =
  "https://raw.githubusercontent.com/QUT-AIML/Constitution/main/Role-Descriptions.md";

marked.setOptions({
  gfm: true,
  breaks: false,
  headerIds: true,
  mangle: false,
});

let rolesHTML = "";

try {
  const res = await fetch(rawURL);
  if (!res.ok) throw new Error(`Failed to fetch: ${res.status}`);

  const md = await res.text();
  const renderer = new marked.Renderer();
  rolesHTML = marked.parse(md, { renderer });
} catch (err) {
  console.error("Error fetching Role Descriptions:", err);
  rolesHTML = `<p>Error loading executive role descriptions.</p>`;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="QUT AI & ML Society Executive Applications"
    />
    <title>QUT AI & ML Society | Executive Applications</title>
  </head>

  <body class="background-dots">
    <Navigation />

    <div class="content-wrapper top-space bottom-space">

      <!-- PAGE TITLE -->
      <section class="pink-panel">
        <p class="pink-title">Executive Applications</p>
      </section>

      <!-- INTRO -->
      <div class="info-panel-wrapper">
        <div class="thick-line-behind"></div>
        <section class="info-panel">
          <p>
            The QUT AI & ML Society executive team is responsible for leading
            the club’s operations, events, and long term direction.
          </p>
        </section>
      </div>

      <!-- WHEN APPLICATIONS OPEN -->
      <section class="pink-panel spacing-above">
        <p class="pink-title">When Do Applications Open?</p>
      </section>

      <div class="info-panel-wrapper">
        <section class="info-panel">
          <p>
            Executive applications open once per year at the club’s
            Annual General Meeting.
          </p>
          <p>
            Every executive position is declared vacant and open for
            re election at the AGM.
          </p>
        </section>
      </div>

      <!-- EXEC STRUCTURE -->
    <section class="pink-panel spacing-above">
      <p class="pink-title">Executive Team Structure</p>
    </section>

    <div class="info-panel-wrapper scroll-horizontal">
      <section class="info-panel">

        <div class="exec-org-chart">

          <!-- ROW 1: CORE EXEC as a single group -->
          <div class="exec-row top-row">
            <div class="exec-group pink-group">
              <div class="group-title">Admin Team</div>
              <div class="exec-sub-row">
                <div class="exec-node">President</div>
                <div class="exec-node">Vice President</div>
                <div class="exec-node">Secretary</div>
                <div class="exec-node">Treasurer</div>
              </div>
            </div>
          </div>

          <!-- SVG CONNECTORS FROM PRESIDENT TO GROUPS -->
          <svg class="exec-lines" width="100%" height="120" xmlns="http://www.w3.org/2000/svg">
            <!-- Marketing Team -->
            <line x1="15%" y1="0" x2="15%" y2="120" stroke="#f6c1d1" stroke-width="2"/>
            <!-- Projects Team -->
            <line x1="40%" y1="0" x2="40%" y2="120" stroke="#f6c1d1" stroke-width="2"/>
            <!-- Events Team -->
            <line x1="65%" y1="0" x2="65%" y2="120" stroke="#f6c1d1" stroke-width="2"/>
            <!-- Support Team -->
            <line x1="90%" y1="0" x2="90%" y2="120" stroke="#f6c1d1" stroke-width="2"/>
          </svg>

          <!-- ROW 2: TEAMS -->
          <div class="exec-row second-row">

            <!-- MARKETING TEAM -->
            <div class="exec-group pink-group">
              <div class="group-title">Marketing Team</div>
              <div class="exec-node">Marketing Director</div>
              <div class="exec-sub-row">
                <div class="exec-node">Social Media Manager</div>
                <div class="exec-node">Reels & Video Officer</div>
                <div class="exec-node">Graphic Designer</div>
              </div>
            </div>

            <!-- PROJECTS TEAM -->
            <div class="exec-group pink-group">
              <div class="group-title">Projects Team</div>
              <div class="exec-sub-row">
                <div class="exec-node">Projects Director</div>
                <div class="exec-node">Projects Manager</div>
              </div>
              <div class="exec-sub-row wrap">
                <div class="exec-node">Projects Officer</div>
                <div class="exec-node">Projects Officer</div>
                <div class="exec-node">Projects Officer</div>
                <div class="exec-node">Projects Officer</div>
                <div class="exec-node">Projects Officer</div>
              </div>
            </div>

            <!-- EVENTS TEAM -->
            <div class="exec-group pink-group">
              <div class="group-title">Events Team</div>
              <div class="exec-node">Events Director</div>
              <div class="exec-sub-row">
                <div class="exec-node">Activities Facilitator</div>
                <div class="exec-node">Activities Facilitator</div>
                <div class="exec-node">Activities Facilitator</div>
              </div>
            </div>

            <!-- SUPPORT TEAM -->
            <div class="exec-group pink-group">
              <div class="group-title">Support Team</div>
              <div class="exec-sub-row">
                <div class="exec-node">Industry Director</div>
                <div class="exec-node">Engagement Officer</div>
              </div>
            </div>

          </div>
        </div>

      </section>
    </div>




      <!-- ROLES AND RESPONSIBILITIES -->
      <section class="pink-panel spacing-above">
        <p class="pink-title">Roles and Responsibilities</p>
      </section>

      <div class="info-panel-wrapper">
        <section class="info-panel special-padding">
          <div class="roles-content" set:html={rolesHTML}></div>
        </section>
      </div>

    </div>

    <Footer />
  </body>
</html>
